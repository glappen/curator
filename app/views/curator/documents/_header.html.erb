<%# Renders the document show-page metadata header. Wrapped in a turbo-frame
    so embedding create/destroy can replace it via broadcast — Curator::Embedding
    after_*_commit callbacks target dom_id(document, :header). The X-of-Y
    line is computed live from `Curator::Embedding` rows that match the KB's
    *current* `embedding_model`; rows with a stale model count as missing
    so a model swap surfaces work-to-redo. %>
<%
  kb     = document.knowledge_base
  counts = document.chunk_status_counts(embedding_model: kb.embedding_model)
  # Engine url helpers reached for directly so Turbo broadcasts — which
  # render through the host app's ApplicationController.renderer — can
  # rebuild the header without crashing on missing route helpers. Same
  # workaround the documents row partial uses.
  routes = Curator::Engine.routes.url_helpers
%>
<%# `target: "_top"` so the Re-ingest / Delete `button_to` forms break out
    of this frame — both controller actions redirect to the documents index,
    which has no matching frame and would otherwise render "Content missing".
    Embedding broadcasts replacing this frame still work; they target the
    frame by dom_id over Cable, not via in-page form navigation. %>
<%= turbo_frame_tag dom_id(document, :header), class: "document-header", target: "_top" do %>
  <div class="document-header__top">
    <h1 class="document-header__title"><%= document.title %></h1>

    <div class="document-header__actions">
      <%= button_to "Re-ingest",
                    routes.reingest_knowledge_base_document_path(document.knowledge_base, document),
                    method: :post,
                    class:  "btn",
                    form:   { data: { turbo_confirm: "Re-ingest \"#{document.title}\"? This rebuilds all chunks and embeddings." } } %>
      <%= button_to "Delete",
                    routes.knowledge_base_document_path(document.knowledge_base, document),
                    method: :delete,
                    class:  "btn btn--danger",
                    form:   { data: { turbo_confirm: "Delete \"#{document.title}\"? This removes all chunks, embeddings, and retrieval history." } } %>
    </div>
  </div>

  <dl class="document-header__meta">
    <div>
      <dt>Type</dt>
      <dd class="text-mono"><%= document.mime_type %></dd>
    </div>
    <div>
      <dt>Size</dt>
      <dd><%= number_to_human_size(document.byte_size) %></dd>
    </div>
    <div>
      <dt>Status</dt>
      <dd><span class="badge <%= document.status_badge_class %>"><%= document.status %></span></dd>
    </div>
    <div>
      <dt>Chunks</dt>
      <dd><%= counts[:total] %></dd>
    </div>
    <div>
      <dt>Embedded</dt>
      <dd><%= counts[:embedded] %> of <%= counts[:total] %></dd>
    </div>
    <div>
      <dt>Ingested</dt>
      <dd><%= document.created_at.to_fs(:short) %></dd>
    </div>
  </dl>

  <% if document.failed? && document.stage_error.present? %>
    <%# Phase 4 surfaced stage_error via the row badge tooltip; the show
        page is the triage surface, so render it inline as a flash-style
        block where operators can actually read and copy it. %>
    <div class="flash flash--alert document-header__error">
      <%= document.stage_error %>
    </div>
  <% end %>
<% end %>
