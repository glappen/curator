<%# Console form. POSTs to /curator/console/run, which enqueues
    Curator::ConsoleStreamJob. The job streams deltas back over the
    Action Cable subscription that show.html.erb established with
    `turbo_stream_from @topic` — the hidden `topic` field below
    round-trips that UUID into the job. %>
<%= form_with url: curator.console_run_path,
              method: :post,
              class:  "form console-form" do |f| %>
  <%= f.hidden_field :topic, value: topic %>
  <%# `:console` for direct Console use; `:console_review` round-trips
      when the page was opened from a Retrievals-tab "Re-run in Console"
      deep link, so the resulting retrieval gets tagged as review-loop
      noise (default-hidden from the Retrievals index). %>
  <%= f.hidden_field :origin, value: origin %>

  <div class="field">
    <%= f.label :knowledge_base_slug, "Knowledge base" %>
    <%= f.select :knowledge_base_slug,
                 knowledge_bases.map { |kb| [kb.name, kb.slug] },
                 { selected: knowledge_base.slug } %>
  </div>

  <div class="field">
    <%= f.label :query %>
    <%= f.text_area :query, value: query, rows: 4, required: true,
                    placeholder: "Ask a question..." %>
  </div>

  <fieldset class="console-form__overrides">
    <legend>Per-run overrides</legend>

    <div class="field">
      <%= f.label :chunk_limit, "Chunk limit (top-K)" %>
      <%= f.number_field :chunk_limit,
                         value: chunk_limit,
                         min: 1,
                         placeholder: knowledge_base.chunk_limit.to_s %>
    </div>

    <div class="field">
      <%= f.label :similarity_threshold %>
      <%= f.number_field :similarity_threshold,
                         value: similarity_threshold,
                         step: 0.01, min: 0, max: 1,
                         placeholder: knowledge_base.similarity_threshold.to_s %>
    </div>

    <div class="field">
      <%= f.label :strategy, "Retrieval strategy" %>
      <%= f.select :strategy,
                   Curator::ConsoleController::STRATEGIES.map { |s| [s.titleize, s] },
                   { selected: strategy.presence || knowledge_base.retrieval_strategy } %>
    </div>

    <div class="field">
      <%= f.label :chat_model %>
      <%= render "curator/shared/model_select",
                 form:    f,
                 field:   :chat_model,
                 options: chat_model_options,
                 current: chat_model.presence || knowledge_base.chat_model %>
    </div>

    <div class="field">
      <%= f.label :system_prompt %>
      <%= f.text_area :system_prompt, value: system_prompt, rows: 4,
                      placeholder: knowledge_base.system_prompt.presence ||
                                   "(KB default — leave blank to use)" %>
    </div>
  </fieldset>

  <div class="form__actions">
    <%= f.submit "Run", class: "btn btn--primary" %>
    <%= link_to "Reset to KB defaults",
                curator.knowledge_base_console_path(knowledge_base),
                class: "btn" %>
  </div>
<% end %>
