/spec/dummy/app/models/message.rb
/spec/dummy/app/models/model.rb
/spec/dummy/app/models/tool_call.rb
/spec/dummy/app/agents/
/spec/dummy/app/prompts/
/spec/dummy/app/schemas/
/spec/dummy/app/tools/
/spec/dummy/log/*.log
/spec/dummy/log/test.log.*
/spec/dummy/storage/
/spec/dummy/tmp/

