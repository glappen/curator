<h1>Query Testing Console</h1>

<%# Per-tab broadcast topic. Action Cable subscription is established once
    here; the form's hidden field round-trips the same UUID so
    Curator::ConsoleStreamJob broadcasts back into this tab and not any
    other. Refreshing the page mints a new topic. %>
<%= turbo_stream_from @topic %>

<div class="console-shell">
  <section class="console-shell__form">
    <%= render "form",
               knowledge_base:       @knowledge_base,
               knowledge_bases:      @knowledge_bases,
               chat_model_options:   @chat_model_options,
               topic:                @topic,
               origin:               @origin,
               query:                @query,
               chunk_limit:          @chunk_limit,
               similarity_threshold: @similarity_threshold,
               strategy:             @strategy,
               chat_model:           @chat_model,
               system_prompt:        @system_prompt %>
  </section>

  <section class="console-shell__answer">
    <header class="console-shell__head">
      <h2>Answer</h2>
      <div id="console-status">
        <%= render "status", state: :idle, message: nil %>
      </div>
    </header>
    <%# `console-stream` Stimulus controller reorders streamed answer
        chunks by `data-seq` — Action Cable's pubsub does not guarantee
        in-order delivery on a single stream, so spans can land out of
        order. See `app/javascript/controllers/curator/console_stream_controller.js`. %>
    <div id="console-answer" class="console-answer" data-controller="console-stream"></div>

    <%# M7 Phase 2 — Curator::ConsoleStreamJob fills this slot on `:done`
        with the thumbs widget; clicking either thumb returns a
        turbo_stream that swaps in the rating-aware evaluations form. %>
    <div id="console-evaluation" class="console-evaluation-slot"></div>
  </section>

  <section class="console-shell__sources">
    <h2>Sources</h2>
    <div id="console-sources" class="console-sources"></div>
  </section>
</div>
