<%# Self-contained — no helper deps. Turbo Stream broadcasts render
    this partial through `ApplicationController.render` (the *host's*
    base controller, not the engine's), which doesn't carry the
    engine's helper modules. Inlining the badge map keeps row-replace
    broadcasts working from `Curator::Document.after_update_commit`. %>
<%
  badge_class = {
    "pending"    => "badge--neutral",
    "extracting" => "badge--warning",
    "embedding"  => "badge--warning",
    "complete"   => "badge--success",
    "failed"     => "badge--danger",
    "deleting"   => "badge--neutral"
  }.fetch(document.status.to_s, "badge--neutral")

  # `chunk_counts` is a `{ document_id => count }` hash preloaded by the
  # index controller. The broadcast render path renders one row at a
  # time without it; fall back to a single COUNT(*) for that doc.
  chunk_count =
    if (preloaded = local_assigns[:chunk_counts])
      preloaded.fetch(document.id, 0)
    else
      document.chunks.count
    end

  # Same render-context trap as the badge map above: turbo broadcasts go
  # through the host's ApplicationController, which doesn't carry the
  # engine's url helpers. Reach for them on the Engine directly so row
  # replaces from `after_update_commit` keep rendering.
  routes = Curator::Engine.routes.url_helpers
%>
<tr id="<%= dom_id(document) %>">
  <td><%= link_to document.title, routes.knowledge_base_document_path(document.knowledge_base, document) %></td>
  <td class="text-mono"><%= document.mime_type %></td>
  <td><%= number_to_human_size(document.byte_size) %></td>
  <td>
    <span class="badge <%= badge_class %>"><%= document.status %></span>
    <%# Stage error rendered inline rather than via `title` — native
        tooltips have a ~700ms delay and a small hover target, so the
        information was effectively invisible. Phase 6 will move this
        to the doc-show header where it can be styled prominently. %>
    <% if document.stage_error.present? %>
      <div class="document-row__error" title="<%= document.stage_error %>">
        <%= document.stage_error %>
      </div>
    <% end %>
  </td>
  <td><%= chunk_count %></td>
  <td><%= document.created_at.to_fs(:short) %></td>
  <td class="document-row__actions">
    <%= button_to "Re-ingest",
                  routes.reingest_knowledge_base_document_path(document.knowledge_base, document),
                  method: :post,
                  class:  "btn",
                  form:   { data: { turbo_confirm: "Re-ingest \"#{document.title}\"? This rebuilds all chunks and embeddings." } } %>
    <%= button_to "Delete",
                  routes.knowledge_base_document_path(document.knowledge_base, document),
                  method: :delete,
                  class:  "btn btn--danger",
                  form:   { data: { turbo_confirm: "Delete \"#{document.title}\"? This removes all chunks, embeddings, and retrieval history." } } %>
  </td>
</tr>
