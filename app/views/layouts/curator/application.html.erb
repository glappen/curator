<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Curator</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "curator/curator", media: "all" %>
    <%= turbo_include_tags %>
    <%# Boots the engine's private Stimulus Application (kb switcher,
        drag-drop). `respond_to?` so host apps using jsbundling/esbuild
        — which don't load importmap-rails — render the layout without
        crashing; those hosts wire `import "curator"` from their own
        bundle. %>
    <% if respond_to?(:javascript_importmap_tags) %>
      <%= javascript_importmap_tags "curator" %>
    <% end %>
  </head>
  <body class="curator-ui">
    <div class="app-shell">
      <header class="app-header">
        <div class="app-header__inner">
          <h1 class="app-header__title">
            <%= link_to "Curator", curator.root_path %>
          </h1>

          <nav class="app-nav" aria-label="Primary">
            <%= link_to "Knowledge bases",
                        curator.root_path,
                        class: class_names("app-nav__link",
                                           "app-nav__link--active" => nav_link_active?(:knowledge_bases, :documents)) %>
            <%= link_to "Console",
                        curator.console_path,
                        class: class_names("app-nav__link",
                                           "app-nav__link--active" => nav_link_active?(:console)) %>
          </nav>

          <div class="app-header__slot">
            <%= render "curator/shared/kb_switcher" %>
          </div>
        </div>
      </header>

      <main class="app-main">
        <% flash.each do |level, message| %>
          <div class="flash flash--<%= level %>"><%= message %></div>
        <% end %>

        <%= yield %>
      </main>

      <footer class="app-footer">
        Curator <%= Curator::VERSION %>
      </footer>
    </div>
  </body>
</html>
