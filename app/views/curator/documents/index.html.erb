<%= turbo_stream_from @knowledge_base, "documents" %>

<div class="card">
  <p class="card__back">
    <%= link_to "← All knowledge bases", knowledge_bases_path %>
  </p>

  <div class="page-header">
    <div>
      <h1><%= @knowledge_base.name %> &middot; <span class="text-muted">Documents</span></h1>
      <p class="card__meta">
        <%= link_to "Configuration", knowledge_base_path(@knowledge_base) %>
      </p>
    </div>

    <div class="page-header__actions">
      <%= link_to "Edit",
                  edit_knowledge_base_path(@knowledge_base),
                  class: "btn" %>
      <%= button_to "Delete",
                    knowledge_base_path(@knowledge_base),
                    method: :delete,
                    class:  "btn btn--danger",
                    form:   { data: { turbo_confirm:
                      "Delete \"#{@knowledge_base.name}\"? Every document in " \
                      "this knowledge base will be permanently deleted along " \
                      "with its chunks, embeddings, and retrieval history. " \
                      "To restore them you would need to re-upload and " \
                      "re-embed every document. This cannot be undone." } } %>
    </div>
  </div>

  <%= render "upload_form", knowledge_base: @knowledge_base %>

  <table class="table">
    <thead>
      <tr>
        <th scope="col">Title</th>
        <th scope="col">Type</th>
        <th scope="col">Size</th>
        <th scope="col">Status</th>
        <th scope="col">Chunks</th>
        <th scope="col">Ingested</th>
        <th scope="col">Actions</th>
      </tr>
    </thead>
    <tbody id="<%= dom_id(@knowledge_base, :documents) %>">
      <%= render partial: "document",
                 collection: @documents,
                 as:         :document,
                 locals:     { chunk_counts: @chunk_counts } %>
      <%# Hidden via :has() once any non-empty-state row joins the tbody.
          Lets the broadcast-driven append path coexist with the empty
          state without a separate "remove empty-state" stream message. %>
      <tr class="empty-state-row">
        <td colspan="7" class="text-muted">
          No documents yet. Upload one to get started.
        </td>
      </tr>
    </tbody>
  </table>

  <%= render "curator/shared/pagination",
             page: @page,
             path_for: ->(n) { knowledge_base_documents_path(@knowledge_base, page: n, per: @page.per) } %>
</div>
