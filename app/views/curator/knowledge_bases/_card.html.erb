<%# URL helpers come from `Curator::Engine.routes.url_helpers` so the partial
    renders correctly both in normal request flow AND in Turbo broadcast
    context (broadcasts render via ApplicationController.renderer, which
    does not automatically expose engine routes via the unqualified helpers
    — and engine helper modules don't ride along either). Phase 3 link
    target — `kbs/:slug/documents` — is mounted by Phase 4. %>
<% url = Curator::Engine.routes.url_helpers %>
<%# `docs_count` and `last_ingested` are preloaded by the index controller
    via two grouped aggregates. The broadcast render path (KB or Document
    after_*_commit) doesn't have those locals, so fall back to live queries
    against the single KB being re-rendered. %>
<% docs_count    = local_assigns.fetch(:docs_count)    { kb.documents.count } %>
<% last_ingested = local_assigns.fetch(:last_ingested) { kb.documents.maximum(:created_at) } %>
<%# `target: "_top"` so links inside the card (KB title, Edit) drive a
    full-page navigation. Without it Turbo treats clicks as in-frame
    requests and the documents index — which has no matching frame —
    renders "Content missing." The frame still exists so KB and
    Document broadcasts can replace it via `dom_id(kb, :card)`. %>
<%= turbo_frame_tag dom_id(kb, :card), class: "card kb-card", target: "_top" do %>
  <h2 class="card__title">
    <%= link_to kb.name, "#{url.knowledge_base_path(kb)}/documents" %>
    <% if kb.is_default? %>
      <span class="badge badge--accent">default</span>
    <% end %>
  </h2>

  <p class="card__meta">
    <span class="text-mono"><%= kb.slug %></span>
  </p>

  <% if kb.description.present? %>
    <p class="kb-card__description"><%= kb.description %></p>
  <% end %>

  <dl class="kb-card__stats">
    <div>
      <dt>Documents</dt>
      <dd><%= docs_count %></dd>
    </div>
    <div>
      <dt>Last ingested</dt>
      <dd>
        <%= last_ingested ? "#{time_ago_in_words(last_ingested)} ago" : "—" %>
      </dd>
    </div>
  </dl>

  <div class="kb-card__actions">
    <%= link_to "Edit", url.edit_knowledge_base_path(kb), class: "btn" %>
    <%= button_to "Delete",
                  url.knowledge_base_path(kb),
                  method: :delete,
                  class:  "btn btn--danger",
                  form:   { data: { turbo_confirm:
                    "Delete \"#{kb.name}\"? Every document in this knowledge " \
                    "base will be permanently deleted along with its chunks, " \
                    "embeddings, and retrieval history. To restore them you " \
                    "would need to re-upload and re-embed every document. " \
                    "This cannot be undone." } } %>
  </div>
<% end %>
