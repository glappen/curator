class CreateCuratorKnowledgeBases < ActiveRecord::Migration[7.0]
  def change
    create_table :curator_knowledge_bases do |t|
      t.string   :name,                 null: false
      t.string   :slug,                 null: false
      t.text     :description
      t.boolean  :is_default,           null: false, default: false

      t.string   :embedding_model,      null: false
      t.string   :chat_model,           null: false

      t.integer  :chunk_size,           null: false, default: 512
      t.integer  :chunk_overlap,        null: false, default: 50
      t.integer  :chunk_limit,          null: false, default: 5
      # Cosine similarity cutoff for vector retrieval. 0.2 is loose
      # but realistic for OpenAI text-embedding-3-small — relevant
      # chunks typically score 0.2–0.5, so a higher default
      # (we initially shipped 0.7) returns empty results in practice.
      # Operators with stricter corpora should tune up.
      t.decimal  :similarity_threshold, null: false, default: 0.2, precision: 4, scale: 3
      t.string   :retrieval_strategy,   null: false, default: "hybrid"
      t.string   :tsvector_config,      null: false, default: "english"
      # When true and retrieval returns zero hits, Curator.ask skips
      # the LLM and returns a canned refusal. Note this fires only on
      # *empty* hits — marginal hits that squeak past
      # `similarity_threshold` still go to the LLM (which is also
      # instructed to refuse from context, but Answer#refused? stays
      # false). Tune `similarity_threshold` up to make the empty-hits
      # path fire more often.
      t.boolean  :strict_grounding,     null: false, default: true
      t.boolean  :include_citations,    null: false, default: true
      t.text     :system_prompt

      t.timestamps
    end

    add_index :curator_knowledge_bases, :slug, unique: true
    add_index :curator_knowledge_bases, :is_default,
              unique: true,
              where: "is_default = true",
              name:  "index_curator_kb_on_single_default"
    add_check_constraint :curator_knowledge_bases,
                         "chunk_overlap < chunk_size",
                         name: "curator_kb_chunk_overlap_lt_chunk_size"
  end
end
